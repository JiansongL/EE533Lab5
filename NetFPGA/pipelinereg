#!/usr/bin/perl -w
use lib "/usr/local/netfpga/lib/Perl5";
use strict;

# Pipeline Register Addresses
# PIPELINE_BLOCK_ADDR = 0x4, REG_ADDR_WIDTH = 4
# Full addr = (BLOCK_ADDR << 6) | (REG_OFFSET << 2)

my $PIPELINE_REG_DMEM_DATA_LO = 0x2000100;  # Offset 0
my $PIPELINE_REG_DMEM_DATA_HI = 0x2000104;  # Offset 1
my $PIPELINE_REG_DMEM_ADDR    = 0x2000108;  # Offset 2
my $PIPELINE_REG_IMEM_ADDR    = 0x200010C;  # Offset 3
my $PIPELINE_REG_IMEM_OUT     = 0x2000110;  # Offset 4 (Hardware reg - read only)

sub regwrite {
   my( $addr, $value ) = @_;
   my $cmd = sprintf( "regwrite 0x%08x 0x%08x", $addr, $value );
   my $result = `$cmd`;
   printf("Write: 0x%08x = 0x%08x\n", $addr, $value);
}

sub regread {
   my( $addr ) = @_;
   my $cmd = sprintf( "regread 0x%08x", $addr );
   my @out = `$cmd`;
   my $result = $out[0];
   if ( $result =~ m/Reg (0x[0-9a-f]+) \((\d+)\):\s+(0x[0-9a-f]+) \((\d+)\)/ ) {
      $result = $3;
   }
   return $result;
}

sub write_instruction {
   my($addr, $instr) = @_;
   printf("Writing instruction 0x%08x to IMEM address 0x%08x\n", $instr, $addr);
   regwrite($PIPELINE_REG_DMEM_DATA_LO, $instr);
   regwrite($PIPELINE_REG_IMEM_ADDR, $addr);
}

sub read_instruction {
   my($addr) = @_;
   regwrite($PIPELINE_REG_IMEM_ADDR, $addr);
   my $instr = regread($PIPELINE_REG_IMEM_OUT);
   printf("Read instruction at IMEM address 0x%08x: 0x%s\n", $addr, $instr);
   return $instr;
}

sub write_data {
   my($addr, $data_lo, $data_hi) = @_;
   printf("Writing data to DMEM address 0x%08x: HI=0x%08x LO=0x%08x\n", $addr, $data_hi, $data_lo);
   regwrite($PIPELINE_REG_DMEM_DATA_LO, $data_lo);
   regwrite($PIPELINE_REG_DMEM_DATA_HI, $data_hi);
   regwrite($PIPELINE_REG_DMEM_ADDR, $addr);
}

sub allregs {
   print "\n=== Pipeline Register Status ===\n";
   print "DMEM_DATA_LO: ", regread($PIPELINE_REG_DMEM_DATA_LO), "\n";
   print "DMEM_DATA_HI: ", regread($PIPELINE_REG_DMEM_DATA_HI), "\n";
   print "DMEM_ADDR:    ", regread($PIPELINE_REG_DMEM_ADDR), "\n";
   print "IMEM_ADDR:    ", regread($PIPELINE_REG_IMEM_ADDR), "\n";
   print "IMEM_OUT:     ", regread($PIPELINE_REG_IMEM_OUT), "\n";
   print "================================\n\n";
}

sub usage {
   print "Usage: pipelinereg <cmd> <cmd options>\n";
   print "  Commands:\n";
   print "    allregs                              displays all registers\n";
   print "    write_inst <addr_hex> <instr_hex>   write instruction to IMEM\n";
   print "    read_inst <addr_hex>                read instruction from IMEM\n";
   print "    write_data <addr_hex> <lo_hex> <hi_hex>  write data to DMEM\n";
   print "    regread <addr_hex>                  read raw register at address\n";
   print "    regwrite <addr_hex> <value_hex>     write raw register at address\n";
}

my $numargs = $#ARGV + 1;
if( $numargs < 1 ) {
   usage();
   exit(1);
}

my $cmd = $ARGV[0];

if ($cmd eq "allregs") {
   allregs();
} elsif ($cmd eq "write_inst") {
   if ($numargs < 3) {
      print "Error: write_inst requires address and instruction\n";
      usage();
      exit(1);
   }
   my $addr = hex($ARGV[1]);
   my $instr = hex($ARGV[2]);
   write_instruction($addr, $instr);
} elsif ($cmd eq "read_inst") {
   if ($numargs < 2) {
      print "Error: read_inst requires address\n";
      usage();
      exit(1);
   }
   my $addr = hex($ARGV[1]);
   read_instruction($addr);
} elsif ($cmd eq "write_data") {
   if ($numargs < 4) {
      print "Error: write_data requires address, data_lo, and data_hi\n";
      usage();
      exit(1);
   }
   my $addr = hex($ARGV[1]);
   my $data_lo = hex($ARGV[2]);
   my $data_hi = hex($ARGV[3]);
   write_data($addr, $data_lo, $data_hi);
} elsif ($cmd eq "regread") {
   if ($numargs < 2) {
      print "Error: regread requires address\n";
      usage();
      exit(1);
   }
   my $addr = hex($ARGV[1]);
   my $val = regread($addr);
   printf("Read from 0x%08x: %s\n", $addr, $val);
} elsif ($cmd eq "regwrite") {
   if ($numargs < 3) {
      print "Error: regwrite requires address and value\n";
      usage();
      exit(1);
   }
   my $addr = hex($ARGV[1]);
   my $val = hex($ARGV[2]);
   regwrite($addr, $val);
} else {
   print "Unrecognized command: $cmd\n";
   usage();
   exit(1);
}
