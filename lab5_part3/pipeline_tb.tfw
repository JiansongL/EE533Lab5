`timescale 1ns/1ps

module pipeline_tb;
    reg clk = 1'b0;
    reg wea = 1'b0;

    parameter PERIOD = 20;
    parameter real DUTY_CYCLE = 0.5;
    parameter OFFSET = 0;

    initial    // Clock process for clk
    begin
        #OFFSET;
        forever
        begin
            clk = 1'b0;
            #(PERIOD-(PERIOD*DUTY_CYCLE)) clk = 1'b1;
            #(PERIOD*DUTY_CYCLE);
        end
    end

    PipelinedDatapath UUT (
        .clk(clk),
        .wea(wea));

    initial begin
        // -------------  Current Time:  985ns
        #985;
        wea = 1'b1;
        // -------------------------------------
        // -------------  Current Time:  2885ns
        #1900;
        wea = 1'b0;
        // -------------------------------------
    end

endmodule

